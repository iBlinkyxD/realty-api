# ── Database ─────────────────────────────────────────────────────────────────
# Local dev: use a local Postgres instance
# Railway: set to the DATABASE_URL injected automatically by the Railway Postgres plugin
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/ilovedrrealty

# ── Supabase (image storage only) ────────────────────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...
STORAGE_BUCKET=listing-images

# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace-with-64-char-hex-string

# Cookie domain — leave blank for localhost; set .ilovedrrealty.com in production
COOKIE_DOMAIN=

# ── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@ilovedrrealty.com

# Logo URL used in email templates — set to CDN URL; falls back to LANDING_URL/iLoveDRRealty_Dark.png
LOGO_URL=

# ── CORS / URLs ───────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5174

# Landing app base URL (used in email links)
LANDING_URL=http://localhost:3000

# ── Runtime ──────────────────────────────────────────────────────────────────
ENVIRONMENT=development
PORT=8000
